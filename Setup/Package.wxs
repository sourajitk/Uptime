<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="Uptime Taskbar App" 
           Manufacturer="Sourajit" 
           Version="1.0.0" 
           UpgradeCode="d2b070bb-d3f3-4d43-85f7-920eb5bd7462"
           Scope="perUserOrMachine">
           
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    
    <!-- Auto-launch configuration on finish dialog -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Uptime Taskbar App" />
    <CustomAction Id="LaunchApplication" FileRef="MainExecutableFile" ExeCommand="" Execute="immediate" Return="asyncNoWait" Impersonate="true" />

    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication" Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>
           
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <!-- Detect and close the application if it is running during installation, uninstallation, or upgrade -->
    <util:CloseApplication Id="CloseApp" 
                           Target="UptimeTaskbarApp.exe" 
                           CloseMessage="yes" 
                           TerminateProcess="1" 
                           RebootPrompt="no" 
                           PromptToContinue="no" />

    <!-- Embed the cab file inside the MSI -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Define the Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="UptimeTaskbarApp" />
    </StandardDirectory>

    <!-- Define the components/files to install -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="a4933705-797f-4df5-a19a-2a87df6a8f5d">
        <!-- Path to our published standalone exe (relative to UptimeTaskbarApp/Setup) -->
        <File Id="MainExecutableFile" Source="..\bin\Release\net10.0-windows\win-x64\publish\UptimeTaskbarApp.exe" KeyPath="yes" />
        
        <!-- Add a Start Menu Shortcut -->
        <Shortcut Id="ApplicationStartMenuShortcut" 
                  Directory="ProgramMenuFolder" 
                  Name="Uptime Taskbar App" 
                  WorkingDirectory="INSTALLFOLDER" 
                  Advertise="yes" />
      </Component>
    </ComponentGroup>

    <!-- Tell WiX which component group to install -->
    <Feature Id="MainFeature" Title="Uptime Taskbar App" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>
</Wix>
